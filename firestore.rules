rules_version = '2';
// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: transactions
// Document ID: auto-generated string
// Fields:
//   - uid: string (required) - Owner user ID
//   - description: string (required, <100 chars) - Transaction description
//   - amount: number (required) - Gross amount (e.g., pos for sale, neg for expense)
//   - type: string (required, 'sale' or 'expense') - Transaction type
//   - tax: number (required, >= 0) - Amount of tax retained
//   - status: string (required, 'completed' or 'pending' or 'cancelled')
//   - date: string (required, format YYYY-MM-DD)
//   - createdAt: number (required) - Timestamp in milliseconds
//
// Collection: users
// Document ID: same as user uid
// Fields:
//   - uid: string (required)
//   - email: string (required)
//   - displayName: string (required)
//   - phone: string (required)
//   - lgpdConsent: boolean (required)
//   - createdAt: number (required)
//   - updatedAt: number (required)
//
// ===============================================================

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) ||
        request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) ||
        request.resource.data.uid == resource.data.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidTransaction(data) {
      return hasRequiredFields(['uid', 'description', 'amount', 'type', 'tax', 'status', 'date', 'createdAt']) &&
             hasOnlyAllowedFields(['uid', 'description', 'amount', 'type', 'tax', 'status', 'date', 'createdAt']) &&
             data.uid is string && data.uid.size() > 0 &&
             data.description is string && data.description.size() > 0 && data.description.size() <= 150 &&
             data.amount is number &&
             data.type in ['sale', 'expense'] &&
             data.tax is number && data.tax >= 0 &&
             data.status in ['completed', 'pending', 'cancelled'] &&
             data.date is string && data.date.size() > 0 && data.date.size() <= 20 &&
             data.createdAt is number;
    }

    function isValidUserProfile(data) {
      return hasRequiredFields(['uid', 'email', 'displayName', 'phone', 'lgpdConsent', 'createdAt', 'updatedAt']) &&
             hasOnlyAllowedFields(['uid', 'email', 'displayName', 'phone', 'lgpdConsent', 'createdAt', 'updatedAt']) &&
             data.uid is string && data.uid.size() > 0 &&
             data.email is string &&
             data.displayName is string &&
             data.phone is string && data.phone.size() <= 20 &&
             data.lgpdConsent is bool &&
             data.createdAt is number &&
             data.updatedAt is number;
    }

    // ===============================================================
    // Collections
    // ===============================================================
    
    match /users/{userId} {
      allow read: if isOwner(userId);
      
      allow create: if isOwner(userId) && 
                    isValidUserProfile(request.resource.data) && 
                    request.resource.data.uid == userId;
                    
      allow update: if isOwner(userId) &&
                    isValidUserProfile(request.resource.data) &&
                    request.resource.data.uid == userId &&
                    request.resource.data.createdAt == resource.data.createdAt;
    }

    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.uid;
      
      allow create: if isAuthenticated() && 
                    isValidTransaction(request.resource.data) && 
                    uidUnchanged();
                    
      allow update: if isAuthenticated() &&
                    isDocOwner() &&
                    isValidTransaction(request.resource.data) &&
                    uidNotModified() &&
                    request.resource.data.createdAt == resource.data.createdAt;
                    
      allow delete: if isDocOwner();
    }
  }
}
